    "from ultralytics import YOLO\n",
    "# YOLO v11 nano 모델 로드\n",
    "model = YOLO(\"yolo11n.pt\")\n",
    "# 데이터셋을 이용해서 100 에폭 훈련\n",
    "results = model.train(data=\"./datasets/data.yaml\", epochs=100, imgsz=640)\n",
    "# 예측 수행\n",
    "results = model(\"sample.jpg\")"
   ]
