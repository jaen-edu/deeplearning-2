    "model = YOLO(\"yolov8n.pt\")\n",
    " \n",
    "# 하이퍼파라미터 탐색 수행\n",
    "model.tune(\n",
    "    data=\"./datasets/data.yaml\",\n",
    "    epochs=250,\n",
    "    iterations=25, # 탐색 횟수 (예: 25번의 실험)\n",
    "    val=True\n",
    ")"
   ]
